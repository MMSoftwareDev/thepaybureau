# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend (https://resend.com)
# Used for transactional emails sent from the app
RESEND_API_KEY=re_xxxxxxxxxxxx
# Used by Supabase Auth SMTP (same Resend key works)
RESEND_SMTP_PASSWORD=re_xxxxxxxxxxxx

# App URL (used for email callback validation)
NEXT_PUBLIC_APP_URL=https://app.thepaybureau.com

# Platform admin emails (comma-separated) — controls access to /admin routes
PLATFORM_ADMIN_EMAILS=admin@example.com

# Cron secret — protects the /api/cron/* endpoints from unauthorized access
# Set to a random string; Vercel sends this in the Authorization header
CRON_SECRET=your-random-cron-secret

# Upstash Redis (https://upstash.com) — used for rate limiting
# Optional: falls back to in-memory if not set (not suitable for production)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# UptimeRobot (https://uptimerobot.com)
# API key for the Traffic Light status widget — get from UptimeRobot dashboard
UPTIMEROBOT_API_KEY=ur_xxxxxxxxxxxx

# Sentry (https://sentry.io)
# Create a Next.js project in Sentry, then copy the DSN
NEXT_PUBLIC_SENTRY_DSN=https://xxxxxxxxxxxx@o0.ingest.sentry.io/0
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project
# Auth token for uploading source maps during build
SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxx

# Stripe (https://stripe.com)
# Secret key from Stripe Dashboard > Developers > API keys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
# Publishable key (used client-side)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
# Webhook signing secret — from Stripe Dashboard > Developers > Webhooks
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
# Price IDs — create these in Stripe Dashboard > Products
STRIPE_PRICE_UNLIMITED_MONTHLY=price_xxxxxxxxxxxx
STRIPE_PRICE_UNLIMITED_ANNUAL=price_xxxxxxxxxxxx

# Marketing URL (used for cross-domain links from app to marketing site)
NEXT_PUBLIC_MARKETING_URL=https://www.thepaybureau.com

# Brevo (https://brevo.com) — email marketing / newsletter
# API key from Brevo Dashboard > SMTP & API > API Keys
BREVO_API_KEY=xkeysib-xxxxxxxxxxxx

# AI Assistant (https://anthropic.com / https://voyageai.com)
# Anthropic API key for Claude LLM
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
# Voyage AI API key for document embeddings
VOYAGE_API_KEY=pa-xxxxxxxxxxxx
